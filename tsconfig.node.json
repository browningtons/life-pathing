{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,

    "allowJs": true,
    "strict": false
  },
  "include": ["vite.config.js", "eslint.config.js", "postcss.config.js", "tailwind.config.js"]
}
